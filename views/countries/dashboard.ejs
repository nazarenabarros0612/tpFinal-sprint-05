<h1 class="mb-4">Dashboard de Países</h1>

<div class="row mb-4">

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5>Población Total</h5>
        <p><%= totalPopulation.toLocaleString() %></p>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5>Área Total</h5>
        <p><%= totalArea.toLocaleString() %></p>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5>Promedio Gini</h5>
        <p>
          <%= averageGini ? averageGini.toFixed(2) : 'Sin datos' %>
        </p>
      </div>
    </div>
  </div>

</div>

<div class="d-flex justify-content-between align-items-center mb-3">

  <form method="GET" action="/countries" class="d-flex gap-2">

    <input
      type="text"
      name="search"
      class="form-control"
      placeholder="Buscar país"
      value="<%= search %>"
    >

    <button class="btn btn-dark">
      Buscar
    </button>

  </form>

  <a href="/countries/export/csv" class="btn btn-success">
    Exportar CSV
  </a>

</div>

<table class="table table-bordered table-hover align-middle shadow-sm">

  <thead class="table-dark">
    <tr>
      <th>Nombre</th>
      <th>Capital</th>
      <th>Borders</th>
      <th>Área</th>
      <th>Población</th>
      <th>Timezones</th>
      <th>Gini</th>
      <th>Creador</th>
      <th>Acciones</th>
    </tr>
  </thead>

  <tbody>

    <% countries.forEach(country => { %>

      <tr>

        <td><%= country.officialName %></td>

        <td><%= country.capital.join(', ') %></td>

        <td><%= country.borders.join(', ') || 'Sin borders' %></td>

        <td><%= country.area.toLocaleString() %></td>

        <td><%= country.population.toLocaleString() %></td>

        <td><%= country.timezones.join(', ') %></td>

        <td>
          <%= country.gini || 'Sin datos' %>
        </td>

        <td><%= country.creator %></td>

        <td>

          <div class="d-flex gap-2">

            <a
              href="/countries/edit/<%= country._id %>"
              class="btn btn-warning btn-sm"
            >
              Editar
            </a>

            <form
              action="/countries/delete/<%= country._id %>?_method=DELETE"
              method="POST"
            >

              <button
                class="btn btn-danger btn-sm"
                onclick="return confirm('¿Seguro que deseas eliminar este país?')"
              >
                Eliminar
              </button>

            </form>

          </div>

        </td>

      </tr>

    <% }) %>

  </tbody>

</table>

<div class="d-flex justify-content-center gap-3 mt-4">

  <% if(currentPage > 1){ %>

    <a
      href="/countries?page=<%= currentPage - 1 %>&search=<%= search %>"
      class="btn btn-outline-dark"
    >
      Anterior
    </a>

  <% } %>

  <span class="fw-bold align-self-center">
    Página <%= currentPage %> de <%= totalPages %>
  </span>

  <% if(currentPage < totalPages){ %>

    <a
      href="/countries?page=<%= currentPage + 1 %>&search=<%= search %>"
      class="btn btn-outline-dark"
    >
      Siguiente
    </a>

  <% } %>

</div>